{
  "name": "kungfu-mcp",
  "version": "1.0.0",
  "description": "A humorous MCP server that catalogs major kungfu factions and narrates sparring matches. For presentation demos.",
  "type": "module",
  "scripts": {
    "build": "tsc && tsc -p tsconfig.ui.json && vite build",
    "start": "npm run build && node build/server.js",
    "dev": "tsx server.ts",
    "inspect": "npx @modelcontextprotocol/inspector"
  },
  "dependencies": {
    "@mastra/core": "^1.50.1",
    "@mastra/mcp": "^1.13.1",
    "@modelcontextprotocol/ext-apps": "^1.7.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "tsx": "^4.23.0",
    "typescript": "^5.6.0",
    "vite": "^8.1.3",
    "vite-plugin-singlefile": "^2.3.3"
  }
}
